value":0.0}],"effects":[],"behaviors":[],"fillOpacity":255.0,"outlineSize":1,"outlineOpacity":255.0,"absoluteCoordinates":false,"clearBetweenFrames":false,"antialiasing":"none","fillColor":{"r":255.0,"g":255.0,"b":255.0},"outlineColor":{"r":0.0,"g":0.0,"b":0.0}}],"objectsFolderStructure":{"folderName":"__ROOT","children":[{"objectName":"ex"},{"objectName":"oh"},{"objectName":"NewTiledSprite"},{"objectName":"NewPanelSprite"},{"objectName":"NewShapePainter"},{"objectName":"NewSprite"}]},"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Tween::TweenCameraZoom2"},"parameters":["","\":wo\"","ex.Sprite()+1","","\"swingTo\"","0.5"]},{"type":{"value":"SetLayerEffectParameter"},"parameters":["","\"void\"","\"Effect3\"","\"angle\"","CameraZoom(\"\", )"]},{"type":{"value":"OpacityCapability::OpacityBehavior::SetValue"},"parameters":["NewSprite","Opacity","=","100+20*(CameraZoom(\"\", )-1)"]},{"type":{"value":"ZoomCamera"},"parameters":["","CameraZoom(\"\", )*0.7*CameraZoom(\"\", )","\"stars\"",""]},{"type":{"value":"SetCameraCenterX"},"parameters":["","=","CameraCenterX(\"\", )*0.9","\"stars\"",""]},{"type":{"value":"SetCameraCenterY"},"parameters":["","=","CameraCenterY(\"\", )*0.9","\"stars\"",""]},{"type":{"value":"CenterCameraOnObject"},"parameters":["","NewPanelSprite","","",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextJustPressed"},"parameters":["","\"Up\""]}],"actions":[{"type":{"value":"ChangeSprite"},"parameters":["ex","+","1"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextJustPressed"},"parameters":["","\"Down\""]}],"actions":[{"type":{"value":"ChangeSprite"},"parameters":["ex","-","1"]}]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"stars","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"SceneJust